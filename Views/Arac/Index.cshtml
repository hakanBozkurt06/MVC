@model IEnumerable<Arac>

@{
    ViewData["Title"] = "Index";
}

<h1>Araç Listesi</h1>

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Mesaj"]
    </div>
}

@* <ul>
    @foreach (var item in Model)
    {
        <li>@item.Marka - @item.Model</li>
    }
</ul> *@

<table class="table">
    <thead>
        <tr>
            <th>Marka</th>
            <th>Model</th>
            <th>Yılı</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Marka</td>
                <td>@item.Model</td>
                <td>@item.Yil</td>
                <td>
                    <a asp-action="AracDuzenle" asp-controller="Arac" asp-route-id="@item.AracId" class="btn btn-sm btn-warning">Düzenle</a>
                    <a asp-action="AracSil" asp-controller="Arac" asp-route-id="@item.AracId" class="btn btn-sm btn-danger">Sil</a>
                    <a asp-action="AracBilgi" asp-controller="Arac" asp-route-id="@item.AracId" class="btn btn-sm btn-primary">Detay</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="AracEkle" asp-controller="Arac" class="btn btn-success">Yeni Araç Ekle</a>
