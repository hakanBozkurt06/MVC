@model Arac
@{
    ViewData["Title"] = "AracEkle";
    ViewData["Desc"] = "Araç ekleme sayfası";
}

<h1>Araç Ekle</h1>

<div class="form-container">
    <form asp-action="AracEkle" asp-controller="Arac" method="post">
        <div class="mb-3">
            <label asp-for="Marka" class="form-label"></label>
            <input asp-for="Marka" class="form-control" />
            <span asp-validation-for="Marka" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Model" class="form-label"></label>
            <input asp-for="Model" class="form-control" />
            <span asp-validation-for="Model" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Yil" class="form-label"></label>
            <input asp-for="Yil" class="form-control" />
            <span asp-validation-for="Yil" class="text-danger"></span>
        </div>
        <input type="submit" name="btnKaydet" value="Kaydet" class="btn btn-primary" />
        <a asp-action="Index" asp-controller="Arac" class="btn btn-secondary">İptal</a>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
